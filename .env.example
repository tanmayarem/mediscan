# AI Provider API Keys (choose one)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Google Translate API (if using Google Translate instead of LibreTranslate)
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Flask Secret Key (required, generate a random one)
FLASK_SECRET_KEY=generate_a_secure_random_key_here